<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.chat.chat_backend.modules.friend.mapper.FriendMapper">

    <select id="findFriendRelation" resultType="com.chat.chat_backend.modules.friend.entity.Friend">
        SELECT f.* FROM friend f
        WHERE f.user_id = #{userId} AND f.friend_id = #{friendId}
    </select>

    <select id="findAllByUserId" resultType="com.chat.chat_backend.modules.friend.entity.Friend">
        SELECT f.* FROM friend f WHERE f.user_id = #{userId}
    </select>

</mapper>