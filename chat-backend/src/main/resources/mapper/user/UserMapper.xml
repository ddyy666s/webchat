<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.chat.chat_backend.modules.user.mapper.UserMapper">

    <select id="findByUsername" resultType="com.chat.chat_backend.modules.user.entity.User">
        SELECT * FROM user WHERE username = #{username}
    </select>

    <select id="countOnlineUsers" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM user WHERE last_login_time > DATE_SUB(NOW(), INTERVAL 5 MINUTE)
    </select>

</mapper>