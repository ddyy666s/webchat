<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.chat.chat_backend.modules.emoji.mapper.EmojiMapper">

    <select id="findSystemEmojis" resultType="com.chat.chat_backend.modules.emoji.entity.Emoji">
        SELECT * FROM emoji
        WHERE is_system = 1
        ORDER BY category, id
    </select>

    <select id="findUserEmojis" resultType="com.chat.chat_backend.modules.emoji.entity.Emoji">
        SELECT * FROM emoji
        WHERE user_id = #{userId} AND is_system = 0
        ORDER BY created_at DESC
    </select>

</mapper>