<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.chat.chat_backend.modules.group.mapper.GroupMapper">

    <select id="findGroupsByUserId" resultType="com.chat.chat_backend.modules.group.entity.Group">
        SELECT g.* FROM chat_group g
                            INNER JOIN group_member gm ON g.id = gm.group_id
        WHERE gm.user_id = #{userId}
    </select>


</mapper>